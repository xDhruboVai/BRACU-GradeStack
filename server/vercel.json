{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node"
    },
    "api/parse.py": {
      "runtime": "@vercel/python"
    },
    "api/parse-and-save.py": {
      "runtime": "@vercel/python"
    }
  },
  "routes": [
    {
      "src": "^/api/parse$",
      "dest": "/api/parse.py"
    },
    {
      "src": "^/api/parse-and-save$",
      "dest": "/api/parse-and-save.py"
    },
    {
      "src": "^/health$",
      "dest": "/api/index.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.js"
    }
  ]
}
