{
  "version": 2,
  "routes": [
    {
      "src": "^/api/parse$",
      "dest": "/api/parse.py"
    },
    {
      "src": "^/api/parse-and-save$",
      "dest": "/api/parse-and-save.py"
    },
    {
      "src": "^/health$",
      "dest": "/api/index.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.js"
    }
  ]
}